{
    "version":  6,
    "cmakeMinimumRequired":  {
                                 "major":  3,
                                 "minor":  28,
                                 "patch":  0
                             },
    "configurePresets":  [
                             {
                                 "name":  "default",
                                 "displayName":  "Default (Ninja + MSVC)",
                                 "description":  "Out-of-source build using Ninja generator with MSVC toolchain",
                                 "generator":  "Ninja",
                                 "binaryDir":  "${sourceDir}/build",
                                 "cacheVariables":  {
                                                        "CMAKE_CXX_COMPILER":  "cl.exe",
                                                        "CMAKE_BUILD_TYPE":  "Debug"
                                                    }
                             },
                             {
                                 "name":  "release",
                                 "displayName":  "Release (Ninja + MSVC)",
                                 "description":  "Out-of-source release build using Ninja generator with MSVC toolchain",
                                 "inherits":  "default",
                                 "cacheVariables":  {
                                                        "CMAKE_BUILD_TYPE":  "Release"
                                                    }
                             }
                         ],
    "buildPresets":  [
                         {
                             "name":  "default",
                             "configurePreset":  "default"
                         },
                         {
                             "name":  "release",
                             "configurePreset":  "release"
                         }
                     ],
    "testPresets":  [
                        {
                            "name":  "default",
                            "configurePreset":  "default"
                        },
                        {
                            "name":  "release",
                            "configurePreset":  "release"
                        }
                    ]
}